                "type": "string"
              },
              {
                "id": "keywords-id",
                "name": "keywords",
                "value": "[\"immich\", \"mealie\", \"netbird\", \"netbox\", \"paperless-ngx\", \"tailscale\", \"waybar\"]",
                "type": "array"
              }
            ]
          }
        }
      },
      {
        "id": "390c82d7-0880-4992-9311-9b3a2f7efcf0",
        "name": "Build GH Query",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          352,
          -208
        ],
        "parameters": {
          "mode": "runOnceForAllItems",
          "language": "javaScript",
          "jsCode": "\nconst repo = $input.first().json.gh_repo;\nconst keywords = $input.first().json.keywords;\n\nconst chunks = [];\nfor (let i = 0; i < keywords.length; i += 5) {\n  chunks.push(keywords.slice(i, i + 5));\n}\n\nreturn chunks.map(chunk => ({\n  query: `repo:${repo} type:pr is:open in:title (${chunk.join(' OR ')})`,\n  repo_owner: repo.split('/')[0],\n  repo_name: repo.split('/')[1]\n}));\n"
        }
      },
      {
        "id": "867cdc6a-d024-4586-9bea-b1467bff8aeb",
        "name": "Fetch matching PRs",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          512,
          -208
        ],
        "parameters": {
          "url": "=https://api.github.com/search/issues?q={{ $json.query }}",
          "options": {}
        }
      },
      {
        "id": "f32dbbe9-c6ef-4e67-aa88-66b19e789bcb",
        "name": "Process response",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          672,
          -208
        ],
        "parameters": {
          "mode": "runOnceForAllItems",
          "language": "javaScript",
          "jsCode": "\nconst all_responses = $input.all();\nconst pr_numbers = new Set();\nconst prs = [];\n\nfor (const response of all_responses) {\n  const items = response.json.items || [];\n  for (const item of items) {\n    // Filter out backport PRs\n    const title = item.title || \"\";\n    if (title.toLowerCase().includes(\"[backport\")) {\n      continue;\n    }\n\n    if (!pr_numbers.has(item.number)) {\n      pr_numbers.add(item.number);\n      prs.push(item);\n    }\n  }\n}\n\nreturn {\n  pr_numbers: Array.from(pr_numbers),\n  prs: prs\n};\n"
        }
      },
      {
        "id": "30732d4e-35ba-4e08-a7f9-74d88952edec",
        "name": "Convert JSON response to binary",
        "type": "n8n-nodes-base.convertToFile",
        "typeVersion": 1.1,
        "position": [
          832,
          -208
        ],
        "parameters": {
          "operation": "toJson"
        }
      },
      {
        "id": "152bafeb-63c2-4743-9eea-70816a3b89c0",
        "name": "Write cache file",
        "type": "n8n-nodes-base.readWriteFile",
        "typeVersion": 1,
        "position": [
          1040,
          -96
        ],
        "parameters": {
          "operation": "write",
          "fileName": "/home/node/.n8n-files/pr_data.json"
        }
      },
      {
        "id": "82d5d0a3-30e8-4448-9aa7-2b6512024554",
        "name": "Compare new and cached PR data",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1232,
          -368
        ],
        "parameters": {
          "mode": "runOnceForAllItems",
          "language": "javaScript",
          "jsCode": "\nconst all_items = $input.all();\n// input 0 = Convert cached PR list (cached), input 1 = Process response (current)\nconst cached_item = all_items[0]?.json?.data?.[0] || {};\nconst cur = all_items[1]?.json || {};\n\nconst pr_numbers_prev = cached_item.pr_numbers || [];\nconst pr_numbers_cur = cur.pr_numbers || [];\nconst pr_numbers_diff = pr_numbers_cur.filter(x => !pr_numbers_prev.includes(x));\n\nconst new_prs_data = (cur.prs || []).filter(x => pr_numbers_diff.includes(x.number));\n\nreturn {\n  pr_numbers: {\n    prev: pr_numbers_prev,\n    cur: pr_numbers_cur,\n    diff: pr_numbers_diff\n  },\n  prs: new_prs_data\n};\n"
        }
      },
      {
        "id": "2a758fdf-54ce-43e6-b91c-7c6beb83f2f8",
        "name": "Create email body",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1440,
          -368
        ],
        "parameters": {
          "mode": "runOnceForAllItems",
          "language": "javaScript",
          "jsCode": "\nconst new_prs = $json.prs || [];\nif (new_prs.length === 0) return [];\n\nlet html_body = \"<html><body><h2>New Open PRs from nixos/nixpkgs matching your keywords</h2>\";\nlet text_body = \"New Open PRs from nixos/nixpkgs matching your keywords:\\n\\n\";\n\nfor (const pr of new_prs) {\n  const title = pr.title || \"No Title\";\n  const url = pr.html_url || \"No URL\";\n  const created_at = pr.created_at || \"N/A\";\n  const state = pr.state || \"N/A\";\n  \n  html_body += `<p><strong>Title:</strong> ${title}<br><strong>URL:</strong> <a href=\"${url}\">${url}</a><br><strong>Created:</strong> ${created_at}<br><strong>State:</strong> ${state}</p><hr>`;\n  text_body += `Title    : ${title}\\nURL      : ${url}\\nCreated  : ${created_at}\\nState    : ${state}\\n--------------------------------------------------\\n`;\n}\n\nhtml_body += \"</body></html>\";\n\nreturn {\n  emailBodyHtml: html_body,\n  emailBodyText: text_body\n};\n"
        }
      },
      {
        "id": "755f205b-5b1c-433e-a074-3d5d786de55c",
        "name": "Send Email",
        "type": "n8n-nodes-base.emailSend",
        "typeVersion": 2.1,
        "position": [
          1632,
          -368
        ],
        "parameters": {
          "fromEmail": "n8n@brkn.lol",
          "toEmail": "philipp@schmitt.co",
          "subject": "NixOS/nixpkgs PRs",
          "emailFormat": "both",
          "text": "={{ $json.emailBodyText }}",
          "html": "={{ $json.emailBodyHtml }}",
          "options": {
            "appendAttribution": false
          }
        },
        "webhookId": "c951c6f6-d64f-4053-bb19-637c8c06a616",
        "credentials": {
          "smtp": {
            "id": "dQMUZSPTIO45Dpu7",
            "name": "SMTP account"
          }
        }
      },
      {
        "id": "9fdb09f3-b2b8-45ec-b84e-5cd54e5064f7",
        "name": "Convert new PR data to array",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1440,
          -160
        ],
        "parameters": {
          "mode": "runOnceForAllItems",
          "language": "javaScript",
          "jsCode": "\nconst prs = $json.prs || [];\nreturn prs.map(pr => ({ pr }));\n"
        }
      },
      {
        "id": "5387644a-4d80-41df-b582-2f97dd347eec",
        "name": "Subscribe to PR",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          1632,
          -160
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.github.com/graphql",
          "authentication": "predefinedCredentialType",
          "nodeCredentialType": "githubOAuth2Api",
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={\n  \"variables\": {\n    \"nodeId\": \"{{ $json.pr.node_id }}\"\n  },\n  \"query\": \"mutation($nodeId: ID!) { updateSubscription(input: { subscribableId: $nodeId, state: SUBSCRIBED, clientMutationId: \\\"subscribe-me\\\" }) { clientMutationId } }\"\n}"
        },
        "credentials": {
          "githubOAuth2Api": {
            "id": "POqP3dfytXqTmZo3",
            "name": "GitHub account (OAuth)"
          },
          "githubApi": {
            "id": "2J14Hqh22wmzbnkG",
            "name": "GitHub account (PAT)"
          }
        }
      },
      {
        "id": "d8be3a6c-56c5-40f7-9ec6-8aeddca0bbcf",
        "name": "Schedule Trigger",
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1.2,
        "position": [
          -144,
          -208
        ],
        "parameters": {
          "rule": {
            "interval": [
              {
                "field": "minutes",
                "minutesInterval": 30
              }
            ]
          }
        }
      }
