        "jsCode": "\nconst all_items = $input.all();\n// input 0 = Convert cached PR list (cached), input 1 = Process response (current)\nconst cached_item = all_items[0]?.json?.data?.[0] || {};\nconst cur = all_items[1]?.json || {};\n\nconst pr_numbers_prev = cached_item.pr_numbers || [];\nconst pr_numbers_cur = cur.pr_numbers || [];\nconst pr_numbers_diff = pr_numbers_cur.filter(x => !pr_numbers_prev.includes(x));\n\nconst new_prs_data = (cur.prs || []).filter(x => pr_numbers_diff.includes(x.number));\n\nreturn {\n  pr_numbers: {\n    prev: pr_numbers_prev,\n    cur: pr_numbers_cur,\n    diff: pr_numbers_diff\n  },\n  prs: new_prs_data\n};\n"
      }
    },
    {
      "id": "2a758fdf-54ce-43e6-b91c-7c6beb83f2f8",
      "name": "Create email body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        -368
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "\nconst new_prs = $json.prs || [];\nif (new_prs.length === 0) return [];\n\n// Get keywords from Config node\nconst config = $node[\"Config\"].first().json;\nconst keywords = config.keywords || [];\n\nconst escapeHtml = (unsafe) => {\n  return (unsafe || \"\").toString()\n    .replace(/&/g, \"&amp;\")\n    .replace(/</g, \"&lt;\")\n    .replace(/>/g, \"&gt;\")\n    .replace(/\"/g, \"&quot;\")\n    .replace(/'/g, \"&#039;\");\n};\n\nconst formatDate = (isoString) => {\n  if (!isoString) return \"N/A\";\n  const date = new Date(isoString);\n  return date.toLocaleDateString('en-US', { \n    month: 'short', \n    day: 'numeric', \n    year: 'numeric' \n  });\n};\n\nlet html_body = `\n<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Helvetica, Arial, sans-serif; line-height: 1.5; color: #24292f; background-color: #f6f8fa; margin: 0; padding: 20px; }\n    .container { max-width: 600px; margin: 0 auto; background-color: #ffffff; border: 1px solid #d0d7de; border-radius: 6px; overflow: hidden; }\n    .header { padding: 16px 24px; background-color: #24292f; color: #ffffff; display: flex; align-items: center; }\n    .header h1 { margin: 0; font-size: 18px; font-weight: 600; }\n    .content { padding: 24px; }\n    .pr-item { padding-bottom: 16px; margin-bottom: 16px; border-bottom: 1px solid #d0d7de; }\n    .pr-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }\n    .pr-title { font-size: 16px; font-weight: 600; color: #0969da; text-decoration: none; display: block; margin-bottom: 4px; }\n    .pr-title:hover { text-decoration: underline; }\n    .pr-meta { font-size: 12px; color: #57606a; display: flex; align-items: center; gap: 8px; }\n    .status-open { color: #1a7f37; font-weight: 600; display: inline-flex; align-items: center; }\n    .icon { vertical-align: middle; margin-right: 4px; }\n    .footer { padding: 16px 24px; background-color: #f6f8fa; border-top: 1px solid #d0d7de; font-size: 12px; color: #57606a; }\n    .keywords { margin-top: 8px; display: flex; flex-wrap: wrap; gap: 4px; }\n    .keyword-tag { background-color: #ddf4ff; color: #0969da; padding: 2px 8px; border-radius: 12px; font-weight: 500; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>📮 GitHub nixpkgs PR Digest</h1>\n    </div>\n    <div class=\"content\">\n`;\n\nfor (const pr of new_prs) {\n  const title = escapeHtml(pr.title);\n  const url = pr.html_url || \"#\";\n  const date = formatDate(pr.created_at);\n  const number = pr.number;\n  const user = pr.user?.login || \"unknown\";\n  \n  html_body += `\n      <div class=\"pr-item\">\n        <a href=\"${url}\" class=\"pr-title\">${title} #${number}</a>\n        <div class=\"pr-meta\">\n          <span class=\"status-open\">⊙ Open</span>\n          <span>by <strong>${user}</strong></span>\n          <span>on ${date}</span>\n        </div>\n      </div>\n  `;\n}\n\nhtml_body += `\n    </div>\n    <div class=\"footer\">\n      <div>Active Keywords:</div>\n      <div class=\"keywords\">\n        ${keywords.map(kw => `<span class=\"keyword-tag\">${escapeHtml(kw)}</span>`).join(' ')}\n      </div>\n      <p style=\"margin-top: 16px; font-style: italic;\">This is an automated digest from n8n.brkn.lol</p>\n    </div>\n  </div>\n</body>\n</html>\n`;\n\nlet text_body = \"New Open PRs from nixos/nixpkgs matching your keywords:\\n\\n\";\nfor (const pr of new_prs) {\n  text_body += `[${pr.title}] #${pr.number}\\nURL: ${pr.html_url}\\nBy: ${pr.user?.login} on ${pr.created_at}\\n\\n`;\n}\ntext_body += \"\\nActive Keywords: \" + keywords.join(\", \");\n\nreturn {\n  emailBodyHtml: html_body,\n  emailBodyText: text_body\n};\n"
      }
    },
