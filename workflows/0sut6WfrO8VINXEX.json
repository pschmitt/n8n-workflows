        "jsCode": "const G = \"6Crcx5cJrWQ6w4cG\";\nconst N = \"6gfWcx5q832xJ6XJ\";\nconst eRegex = /^[\\p{Emoji}\\u2000-\\u32FF]/u;\nconst matched = $input.all().filter(i => {\n  const t = i.json;\n  const pid = String(t.project_id);\n  const matchProject = (pid === G || pid === N);\n  const noEmoji = !eRegex.test(String(t.content || \"\").trim());\n  return matchProject && noEmoji;\n}).map(i => ({ json: { ...i.json, is_groceries: String(i.json.project_id) === G } }));\n\n// LIMIT TO 2 ITEMS TO AVOID RATE LIMITS DURING BACKLOG PROCESSING\nreturn matched.slice(0, 2);"
      }
