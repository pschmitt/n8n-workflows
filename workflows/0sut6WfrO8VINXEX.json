      {
        "id": "6e5bce62-5665-4d8a-abbc-e66a6de874f1",
        "name": "Identify Task",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -1250,
          -100
        ],
        "parameters": {
          "language": "javaScript",
          "jsCode": "\nconst G = '6Crcx5cJrWQ6w4cG';\nconst N = '6gfWcx5q832xJ6XJ';\nconst eRegex = /^[\\p{Emoji}\\u2000-\\u32FF]/u; // Matches if starts with emoji or symbols\nreturn $input.all().filter(i => {\n  const t = i.json;\n  const pid = String(t.project_id);\n  // Only process if it's one of our projects and DOES NOT start with an emoji/symbol\n  return (pid === G || pid === N) && t.content && !eRegex.test(t.content.trim());\n}).map(i => ({ json: { ...i.json, project_type: String(i.json.project_id) === G ? 'groceries' : 'nerdery' } }));\n"
        }
      },
      {
        "id": "052d0a03-4e22-475d-a90b-033704424a46",
        "name": "Switch",
        "type": "n8n-nodes-base.switch",
        "typeVersion": 3,
        "position": [
          -1000,
          -100
        ],
        "parameters": {
          "rules": {
            "values": [
              {
                "conditions": {
                  "conditions": [
                    {
                      "leftValue": "={{ $json.project_type }}",
                      "operator": {
                        "type": "string",
                        "operation": "equals"
                      },
                      "rightValue": "groceries"
                    }
                  ]
                }
              },
              {
                "conditions": {
                  "conditions": [
                    {
                      "leftValue": "={{ $json.project_type }}",
                      "operator": {
                        "type": "string",
                        "operation": "equals"
                      },
                      "rightValue": "nerdery"
                    }
                  ]
                }
              }
            ]
          }
        }
      },
      {
        "id": "d3b89066-5ad0-40d8-8fe1-bc7bd126f34b",
        "name": "Get Static Mappings",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          -750,
          -250
        ],
        "parameters": {
          "url": "https://gist.github.com/pschmitt/b5ce05407e6bcaf457923845f6f550c2/raw/emoji-mapping.json",
