        "name": "Switch",
        "type": "n8n-nodes-base.switch",
        "typeVersion": 3.4,
        "position": [
          -1000,
          -100
        ],
        "parameters": {
          "mode": "rules",
          "rules": {
            "values": [
              {
                "conditions": {
                  "options": {
                    "caseSensitive": true
                  },
                  "combinator": "and",
                  "conditions": [
                    {
                      "leftValue": "={{ $json.is_groceries }}",
                      "operator": {
                        "type": "boolean",
                        "operation": "true"
                      }
                    }
                  ]
                }
              },
              {
                "conditions": {
                  "options": {
                    "caseSensitive": true
                  },
                  "combinator": "and",
                  "conditions": [
                    {
                      "leftValue": "={{ $json.is_groceries }}",
                      "operator": {
                        "type": "boolean",
                        "operation": "false"
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      },
      {
        "id": "d3b89066-5ad0-40d8-8fe1-bc7bd126f34b",
        "name": "Get Static Mappings",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.4,
        "position": [
          -750,
          -250
        ],
        "parameters": {
          "url": "https://gist.github.com/pschmitt/b5ce05407e6bcaf457923845f6f550c2/raw/emoji-mapping.json",
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        },
        "executeOnce": true
      },
      {
        "id": "1eeb186b-023d-4057-be06-7807d6f85766",
        "name": "Apply Static Map",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -500,
          -250
        ],
        "parameters": {
          "mode": "runOnceForAllItems",
          "language": "javaScript",
          "jsCode": "const mappings = $input.all().map(i => i.json).filter(m => m.emoji && m.patterns);\nconst tasks = $(\"Identify Task\").all().map(i => i.json);\nconst groceryTasks = tasks.filter(t => t.is_groceries === true);\n\nreturn groceryTasks.map(t => {\n  let matched = false;\n  for (const m of mappings) {\n    const regex = new RegExp(\"^\\\\s*(\" + m.patterns.join(\"|\") + \")\", \"i\");\n    if (regex.test(t.content)) {\n      t.content = `${m.emoji} ${t.content}`;\n      matched = true;\n      break;\n    }\n  }\n  return { json: { ...t, is_matched: matched ? \"yes\" : \"no\" } };\n});"
        }
      },
