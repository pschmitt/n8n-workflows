        "pythonCode": "\nimport re\nitems = [item[\"json\"] for item in _items]\nmappings = [x for x in items if \"emoji\" in x and \"patterns\" in x]\ntasks = [x for x in items if x.get(\"project_type\") == 'groceries']\nout = []\nfor t in tasks:\n    matched = False\n    for m in mappings:\n        if re.search(\"^\\\\s*(\" + \"|\".join(m[\"patterns\"]) + \")\", t[\"content\"], re.IGNORECASE):\n            t[\"content\"] = f\"{m['emoji']} {t['content']}\"\n            out.append({\"json\": {**t, \"is_matched\": \"yes\"}})\n            matched = True\n            break\n    if not matched:\n        out.append({\"json\": {**t, \"is_matched\": \"no\"}})\nreturn out\n"
      }
    },
